generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  passwordHash  String?
  imageId       String?
  imageUrl      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownedLists    VotingList[]
  participations Participant[]
  votes         Vote[]        @relation("Voter")
}

model VotingList {
  id                String    @id @default(cuid())
  name              String
  description       String?
  imageId           String?
  imageUrl          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdById       String
  expiresAt         DateTime?
  revealVotes       Boolean   @default(false)
  allowMultipleVotes Boolean  @default(false)
  rankedVoting      Boolean   @default(false)
  maxRank           Int       @default(5)

  createdBy    User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
  participants Participant[]
  options   Option[]
}

model Participant {
  id       String   @id @default(cuid())
  userId   String
  listId   String
  joinedAt DateTime @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  list VotingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([userId, listId])
  @@index([listId])
}

model Option {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageId     String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  listId      String

  list  VotingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  votes Vote[]

  @@index([listId])
}

model Vote {
  id          String   @id @default(cuid())
  voterId     String
  optionId    String
  rank        Int?
  createdAt   DateTime @default(now())

  voter     User      @relation("Voter", fields: [voterId], references: [id], onDelete: Cascade)
  option    Option    @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([voterId, optionId])
  @@index([optionId])
}
